# Staging Environment Configuration
# Copy this file to .env.staging and fill in your actual values
# This file is for staging/QA deployments

# ============================================
# CLERK AUTHENTICATION - Staging
# ============================================
# Use Staging keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_staging_publishable_key_here
CLERK_SECRET_KEY=sk_test_staging_secret_key_here

# Clerk URLs for Staging
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================
# SUPABASE DATABASE - Staging
# ============================================
# Use Staging database from: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# OPENAI API - Staging
# ============================================
# Use Staging key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_staging_openai_key_here

# ============================================
# APPLICATION SETTINGS - Staging
# ============================================
NEXT_PUBLIC_APP_URL=https://staging.yourdomain.com

# ============================================
# SECURITY & TESTING - Staging
# ============================================
# Enable debug logging for testing
DEBUG=true
LOG_LEVEL=debug

# Rate limiting (more permissive for testing)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=900000

# Test data enabled
ALLOW_TEST_USERS=true

# ============================================
# ANALYTICS & MONITORING - Staging
# ============================================
NEXT_PUBLIC_GA_ID=G_your_staging_google_analytics_id
SENTRY_AUTH_TOKEN=your_sentry_staging_token
SENTRY_PROJECT_ID=your_sentry_staging_project_id
SENTRY_ENVIRONMENT=staging

# ============================================
# DEPLOYMENT SETTINGS
# ============================================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
