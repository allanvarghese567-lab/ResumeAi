# Production Environment Configuration
# Copy this file to .env.production and fill in your actual values
# This file is for production deployments only

# ============================================
# CLERK AUTHENTICATION - Production
# ============================================
# Use Production keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
CLERK_SECRET_KEY=sk_live_your_secret_key_here

# Clerk URLs for Production
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================
# SUPABASE DATABASE - Production
# ============================================
# Use Production database from: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# OPENAI API - Production
# ============================================
# Use Production key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_production_openai_key_here

# ============================================
# APPLICATION SETTINGS - Production
# ============================================
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ============================================
# SECURITY & PERFORMANCE - Production
# ============================================
# Enable HTTPS enforcement
NEXT_PUBLIC_ENFORCE_HTTPS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# CORS settings
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# ANALYTICS & MONITORING - Production
# ============================================
NEXT_PUBLIC_GA_ID=G_your_google_analytics_id
SENTRY_AUTH_TOKEN=your_sentry_token
SENTRY_PROJECT_ID=your_sentry_project_id

# ============================================
# DEPLOYMENT SETTINGS
# ============================================
# Vercel deployment
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
